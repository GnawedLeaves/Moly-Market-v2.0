{
  "family": "notification",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "256",
  "memory": "512",
  "containerDefinitions": [
    {
      "name": "notification",
      "image": "088989221715.dkr.ecr.ap-southeast-2.amazonaws.com/molymarket/notification:v1.3",
      "portMappings": [
        {
          "containerPort": 8084,
          "hostPort": 8084,
          "protocol": "tcp",
          "name": "8084",
          "appProtocol": "http"
        }
      ],
      "essential": true,
      "environment": [
        {
          "name": "SPRING_DATASOURCE_HIKARI_MAXIMUM_POOL_SIZE",
          "value": "3"
        },
        {
          "name": "AWS_REGION",
          "value": "ap-southeast-2"
        },
        {
          "name": "SPRING_DATASOURCE_PASSWORD",
          "value": "<REDACTED>"
        },
        {
          "name": "SPRING_DATASOURCE_URL",
          "value": "jdbc:postgresql://molymarket-db.cp222oaeec4l.ap-southeast-2.rds.amazonaws.com:5432/postgres"
        },
        {
          "name": "SPRING_DATASOURCE_USERNAME",
          "value": "postgres"
        },
        {
          "name": "SQS_ENDPOINT",
          "value": "https://sqs.ap-southeast-2.amazonaws.com/088989221715/notification-queue"
        },
        {
          "name": "SECRET_KEY",
          "value": "<REDACTED>"
        },
        {
          "name": "NOTIFICATION_QUEUE",
          "value": "notification-queue"
        },
        {
          "name": "SPRING_CLOUD_AWS_REGION_STATIC",
          "value": "ap-southeast-2"
        },
        {
          "name": "CLOUD_AWS_STACK_AUTO",
          "value": "false"
        },
        {
          "name": "SPRING_CLOUD_AWS_CREDENTIALS_INSTANCE_PROFILE_ENABLED",
          "value": "true"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/notification",
          "awslogs-create-group": "true",
          "awslogs-region": "ap-southeast-2",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ],
  "taskRoleArn": "arn:aws:iam::088989221715:role/molymarket-sqs-task-role",
  "executionRoleArn": "arn:aws:iam::088989221715:role/ecsTaskExecutionRole",
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  }
}
